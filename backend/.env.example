# NetWatch Backend — Environment Variables
# Copy this file to .env and fill in all values before starting.

# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Security ────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_A_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=8h

# ── Database (MySQL 8) ───────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=netwatch
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_NAME=netwatch_erp

# ── Redis (BullMQ queues) ────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# WAJIB di production: set requirepass di redis.conf & isi password di bawah.
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
# Set true hanya jika Redis diakses lintas host via TLS (Redis terkelola).
REDIS_TLS=false

# ── WhatsApp Gateway (internal) ──────────────────────────
# Gateway dibangun sendiri. Endpoint: POST {BASE_URL}/api/v1/messages/send
# Auth via header X-API-Key (format: wag_xxx.yyy).
WAGATEWAY_API_KEY=
WAGATEWAY_BASE_URL=https://wg.aptpairport.id
# id device pengirim (integer). Jika API key terikat ke 1 device, KOSONGKAN (gateway
# pakai device itu otomatis). Jika API key TANPA default device, WAJIB diisi — kalau
# tidak, setiap kirim ditolak HTTP 400 "deviceId wajib diisi".
WAGATEWAY_DEVICE_ID=

# ── CORS ─────────────────────────────────────────────────
# Set to your production domain (e.g. https://netwatch.example.com)
# Not needed when NODE_ENV=production and frontend is served by Express.
CORS_ORIGIN=https://netwatch.example.com

# URL publik aplikasi (untuk link "Ambil"/"Ingatkan" di notifikasi WA).
# Default ikut CORS_ORIGIN bila tidak diset.
APP_URL=https://netwatch.example.com

# URL yang dipakai Puppeteer untuk membuka halaman cetak /doc-print saat membuat PDF
# dokumen dari halaman verifikasi TTE. PRODUCTION: kosongkan (default http://127.0.0.1:PORT —
# Express menyajikan SPA di port yang sama). DEV: arahkan ke Vite, mis. http://127.0.0.1:5173
# SELF_BASE_URL=http://127.0.0.1:5173

# ── Monitoring ───────────────────────────────────────────
# Ping sweep interval in milliseconds (default 15000 = 15s)
PING_INTERVAL_MS=15000
