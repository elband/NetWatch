# NetWatch — Nginx reverse proxy configuration example
# Place at: /etc/nginx/sites-available/netwatch
# Enable: ln -s /etc/nginx/sites-available/netwatch /etc/nginx/sites-enabled/
# Then: nginx -t && systemctl reload nginx

server {
    listen 80;
    server_name netwatch.example.com;

    # Redirect HTTP → HTTPS (uncomment after obtaining SSL cert)
    # return 301 https://$host$request_uri;

    # Upload size limit (incident photos, inspection docs)
    client_max_body_size 20M;

    # Static uploaded files — serve directly without hitting Node
    location /uploads/ {
        alias /var/www/netwatch/backend/uploads/;
        expires 7d;
        add_header Cache-Control "public";
    }

    # WebSocket (Socket.io)
    location /socket.io/ {
        proxy_pass         http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host $host;
        proxy_cache_bypass $http_upgrade;
    }

    # All other traffic → Express (API + SPA)
    location / {
        proxy_pass         http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }
}

# HTTPS block (uncomment and fill in after: certbot --nginx -d netwatch.example.com)
